        "{~Q(f(a))}"
      ],
      "constants": ["a"]
    },
    {
      "id": "pred-03",
      "title": "Multi-step predicate resolution",
      "logicType": "predicate",
      "clauses": [
        "{P(x), Q(x, f(x))}",
        "{~P(g(y)), R(y)}",
        "{~Q(g(a), z)}",
        "{~R(a)}"
      ],
      "constants": ["a"],
      "hints": [
        "Start by resolving clauses that involve the predicate P.",
        "Clause 1 and clause 2 can be resolved on P."
      ]
    },
    {
      "id": "test",
