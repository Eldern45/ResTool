        "{~A, C}",
        "{~B}",
        "{~C}"
      ]
    },
    {
      "id": "prop-02",
      "title": "Three-variable propositional",
      "logicType": "propositional",
      "clauses": [
        "{P, Q}",
        "{~P, R}",
        "{~Q, R}",
        "{~R}"
      ]
    },
    {
      "id": "prop-03",
      "title": "Propositional chain",
      "logicType": "propositional",
      "clauses": [
        "{A}",
        "{~A, B}",
        "{~B, C}",
        "{~C}"
      ]
    },
    {
      "id": "pred-01",
      "title": "Simple predicate resolution",
      "logicType": "predicate",
      "clauses": [
        "{P(x), Q(x)}",
        "{~P(a)}",
        "{~Q(a)}"
      ],
      "constants": ["a"]
    },
    {
      "id": "pred-02",
      "title": "Function symbols",
      "logicType": "predicate",
      "clauses": [
        "{P(x, f(x))}",
